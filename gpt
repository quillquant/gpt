#!/usr/bin/env bash
# Single entrypoint for this repo.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ISOLATED="$ROOT/ollama-isolated.sh"

usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [args]

Setup / UI:
  install                Bootstrap Ollama, venv, private GitHub repo, VERSION
  panel [--daemon|-d]    Start the control panel on http://127.0.0.1:8080
  bench [models...]      Smoke-test APIs and benchmark cold load + chat

Isolated model servers (see also ./ollama-isolated.sh):
  start|start-all|stop|stop-all|list|run|logs

Main Ollama:
  service-start|service-stop|upgrade|update-models
EOF
}

cmd_panel() {
    local web="$ROOT/web"
    local py cand
    local daemon=0
    local arg
    for arg in "$@"; do
        case "$arg" in
            --daemon|-d) daemon=1 ;;
        esac
    done
    cd "$web"
    if [[ ! -d .venv ]]; then
        py=""
        for cand in \
            "${PYTHON:-}" \
            python3.14 python3.13 python3.12 python3.11 \
            /opt/homebrew/bin/python3 \
            /usr/local/bin/python3 \
            python3
        do
            [[ -n "$cand" ]] || continue
            if command -v "$cand" >/dev/null 2>&1 \
                && "$cand" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' 2>/dev/null; then
                py="$(command -v "$cand")"
                break
            fi
        done
        [[ -n "$py" ]] || {
            echo "need Python 3.11+ (brew install python)" >&2
            exit 1
        }
        "$py" -m venv .venv
        export PIP_INDEX_URL="https://pypi.org/simple"
        export PIP_TRUSTED_HOST="pypi.org files.pythonhosted.org"
        unset PIP_EXTRA_INDEX_URL PIP_FIND_LINKS || true
        .venv/bin/pip install -q -r requirements.txt
    fi
    if [[ "$daemon" -eq 1 ]]; then
        # Detach into a new session so the panel survives the launching shell.
        .venv/bin/python - <<'PY'
import subprocess
from pathlib import Path

cmd = [str(Path.cwd() / ".venv/bin/uvicorn"), "server:app", "--host", "127.0.0.1", "--port", "8080"]
log = open("/tmp/gpt-panel.log", "ab", buffering=0)
proc = subprocess.Popen(cmd, stdout=log, stderr=subprocess.STDOUT, start_new_session=True)
Path("/tmp/gpt-panel.pid").write_text(str(proc.pid) + "\n")
print(f"panel started pid={proc.pid}  http://127.0.0.1:8080  (log: /tmp/gpt-panel.log)")
PY
        return 0
    fi
    exec .venv/bin/uvicorn server:app --host 127.0.0.1 --port 8080
}

cmd="${1:-}"
shift || true

case "$cmd" in
    ""|-h|--help|help) usage ;;
    install)           exec "$ROOT/install.sh" "$@" ;;
    panel|serve|web)   cmd_panel "$@" ;;
    bench)             exec "$ROOT/bench.sh" "$@" ;;
    start|start-all|stop|stop-all|list|run|logs|service-start|service-stop|upgrade|update-models)
        exec "$ISOLATED" "$cmd" "$@"
        ;;
    *)
        echo "Unknown command: $cmd" >&2
        usage >&2
        exit 1
        ;;
esac
